# Dev-shell local toolchain state
/.mix/
/.hex/
# Unanchored: shellHook derives this from $PWD, which can be repo root or
# core/ depending on where `nix develop` was invoked from.
.elixir_make_cache/

# Build artifacts (per mix project)
**/_build/
**/deps/
**/node_modules/
**/.elixir_ls/

# SQLite databases (dev/test)
*.db
*.db-*
*.db-shm
*.db-wal

# Elixir crash dumps
erl_crash.dump

# Direnv
.direnv/
.envrc

# Per-machine files generated by scripts/bootstrap.sh (nixos-anywhere
# fresh-machine deploy) — never committed, regenerated every bootstrap run.
/hardware/generated-hardware-configuration.nix
/hardware/generated-disk-device.nix
