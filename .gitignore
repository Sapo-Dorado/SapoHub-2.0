# Dev-shell local toolchain state
/.mix/
/.hex/
# Unanchored: shellHook derives this from $PWD, which can be repo root or
# core/ depending on where `nix develop` was invoked from.
.elixir_make_cache/

# Build artifacts (per mix project)
**/_build/
**/deps/
**/node_modules/
**/.elixir_ls/

# SQLite databases (dev/test)
*.db
*.db-*
*.db-shm
*.db-wal

# Elixir crash dumps
erl_crash.dump

# Direnv
.direnv/
.envrc

# NOTE: hardware/<hostname>-{hardware-configuration,disk-device}.nix,
# generated per-machine by scripts/bootstrap.sh, are deliberately NOT
# ignored — they're committed (by default) so future redeploys of that
# specific host have the real hardware config, not the generic
# placeholder. See scripts/bootstrap.sh's header comment.
